datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Project {
  id                  String        @id @default(uuid())
  name                String
  repoUrl             String        @map("repo_url")
  branch              String
  authTokenEncrypted  String?       @map("auth_token_encrypted")
  createdAt           DateTime      @default(now()) @map("created_at")
  analyses            AnalysisRun[]

  @@map("projects")
}

model AnalysisRun {
  id                   String    @id @default(uuid())
  projectId            String    @map("project_id")
  project              Project   @relation(fields: [projectId], references: [id])
  status               String    // IDLE | CLONING | FILTERING | ANALYZING | GENERATING | COMPLETED | FAILED
  commitSha            String    @map("commit_sha")
  startedAt            DateTime  @default(now()) @map("started_at")
  completedAt          DateTime? @map("completed_at")
  errorMessage         String?   @map("error_message")
  repositoryStatistics Json?     @map("repository_statistics")
  interactionRegistry  Json?     @map("interaction_registry")
  repositoryUnderstanding Json?   @map("repository_understanding")
  aiReadyContext          Json?   @map("ai_ready_context")
  qualityScorecard        Json?   @map("quality_scorecard")
  discoveryContext        Json?   @map("discovery_context")
  featureQualityScorecard Json?   @map("feature_quality_scorecard")
  scenarioDiscoveryContext Json?   @map("scenario_discovery_context")
  scenarioQualityScorecard Json?   @map("scenario_quality_scorecard")
  testCaseDiscoveryContext Json?   @map("test_case_discovery_context")
  testCaseQualityScorecard Json?   @map("test_case_quality_scorecard")
  automationDiscoveryContext Json?   @map("automation_discovery_context")
  automationQualityScorecard Json?   @map("automation_quality_scorecard")
  coverageDiscoveryContext   Json?   @map("coverage_discovery_context")
  coverageQualityScorecard   Json?   @map("coverage_quality_scorecard")
  coverageDashboardPayload   Json?   @map("coverage_dashboard_payload")
  features                Feature[]
  coverageReport          CoverageReport?

  @@map("analysis_runs")
}

model Feature {
  id              String      @id @default(uuid())
  analysisRunId   String      @map("analysis_run_id")
  analysisRun     AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
  featureName     String      @map("feature_name")
  featureType     String      @map("feature_type")
  description     String
  confidenceScore Float       @map("confidence_score")
  evidence        Json
  sourceWorkflows Json        @map("source_workflows")
  riskLevel       String      @map("risk_level")
  createdAt       DateTime    @default(now()) @map("created_at")

  qualityScore               Float?   @map("quality_score")
  completenessScore          Float?   @map("completeness_score")
  evidenceCoverageScore      Float?   @map("evidence_coverage_score")
  workflowCoverageScore      Float?   @map("workflow_coverage_score")
  confidenceReliabilityScore Float?   @map("confidence_reliability_score")
  riskClassificationScore    Float?   @map("risk_classification_score")
  qualityWarnings            Json?    @map("quality_warnings")

  scenarios                  Scenario[]

  @@map("features")
}

model Scenario {
  id                         String      @id @default(uuid())
  scenarioName               String      @map("scenario_name")
  scenarioType               String      @map("scenario_type") // POSITIVE | NEGATIVE | EDGE_CASE | SECURITY | PERFORMANCE | INTEGRATION
  description                String
  confidenceScore            Float       @map("confidence_score")
  evidence                   Json        // String array of files/endpoints supporting this scenario
  sourceWorkflows            Json        // String array of workflows associated with this scenario
  riskLevel                  String      @map("risk_level")
  priority                   String      @map("priority")
  coverageTargets            Json        @map("coverage_targets")
  scenarioOrigin             Json?       @map("scenario_origin")
  createdAt                  DateTime    @default(now()) @map("created_at")
  
  // Implicit many-to-many parents relationship
  features                   Feature[]

  // For Part 4.4 Scenario Quality Evaluator
  qualityScore               Float?      @map("quality_score")
  completenessScore          Float?      @map("completeness_score")
  evidenceCoverageScore      Float?      @map("evidence_coverage_score")
  workflowCoverageScore      Float?      @map("workflow_coverage_score")
  priorityValidityScore      Float?      @map("priority_validity_score")
  riskClassificationScore    Float?      @map("risk_classification_score")
  traceabilityQualityScore   Float?      @map("traceability_quality_score")
  coverageTargetScore        Float?      @map("coverage_target_score")
  confidenceReliabilityScore Float?      @map("confidence_reliability_score")
  qualityWarnings            Json?       @map("quality_warnings")

  // Implicit many-to-many relationship with TestCase
  testCases                  TestCase[]

  @@map("scenarios")
}

model TestCase {
  id                  String           @id @default(uuid())
  testCaseKey         String           @map("test_case_key") // e.g. TC-LOGIN-001
  testCaseName        String           @map("test_case_name")
  testCaseType        String           @map("test_case_type") // FUNCTIONAL | NEGATIVE | EDGE_CASE | SECURITY | PERFORMANCE | INTEGRATION
  priority            String           @map("priority")
  description         String
  preconditions       Json             // Array of strings
  steps               Json             // Array of steps: { stepNumber, action, expectedResult }
  expectedResult      String           @map("expected_result")
  evidence            Json             // Array of strings
  riskLevel           String           @map("risk_level")
  coverageTargets     Json             @map("coverage_targets") // { routes: string[], apis: string[], forms: string[] }
  testCaseOrigin      Json?            @map("test_case_origin") // { featureIds: string[], workflowIds: string[], scenarioIds: string[] }
  contractVersion     String           @default("1.0.0") @map("contract_version")
  createdAt           DateTime         @default(now()) @map("created_at")
  
  // Implicit many-to-many relationship with Scenario
  scenarios           Scenario[]

  // Quality scorecard mapping (One-to-One)
  quality             TestCaseQuality?
  
  // Automation details (Part 6)
  automationStatus    String           @default("UNAUTOMATED") @map("automation_status")
  automationPath      String?          @map("automation_path")
  automationScript    AutomationScript?

  @@map("test_cases")
}

model TestCaseQuality {
  id                String       @id @default(uuid())
  testCaseId        String       @unique @map("test_case_id")
  testCase          TestCase     @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  qualityScore      Float        @map("quality_score")
  completenessScore Float        @map("completeness_score")
  groundingScore    Float        @map("grounding_score")
  traceabilityScore Float        @map("traceability_score")
  stepStructureScore Float       @map("step_structure_score")
  warnings          Json         @map("warnings")
  createdAt         DateTime     @default(now()) @map("created_at")

  @@map("test_case_quality")
}

model AutomationScript {
  id                String            @id @default(uuid())
  testCaseId        String            @unique @map("test_case_id")
  testCase          TestCase          @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  filePath          String            @map("file_path")
  codeContent       String            @map("code_content")
  framework         String            @map("framework")
  confidenceScore   Float             @map("confidence_score")
  automationOrigin  Json              @map("automation_origin")
  contractVersion   String            @default("1.0.0") @map("contract_version")
  createdAt         DateTime          @default(now()) @map("created_at")

  quality           AutomationQuality?

  @@map("automation_scripts")
}

model AutomationQuality {
  id                      String            @id @default(uuid())
  scriptId                String            @unique @map("script_id")
  script                  AutomationScript  @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  qualityScore            Float             @map("quality_score")
  syntaxScore             Float             @map("syntax_score")
  complianceScore         Float             @map("compliance_score")
  maintainabilityScore    Float             @map("maintainability_score")
  groundingScore          Float             @map("grounding_score")
  traceabilityScore       Float             @map("traceability_score")
  crossFileIntegrityScore Float             @map("cross_file_integrity_score")
  warnings                Json              @map("warnings")
  createdAt               DateTime          @default(now()) @map("created_at")

  @@map("automation_quality")
}

model CoverageReport {
  id                      String          @id @default(uuid())
  analysisRunId           String          @unique @map("analysis_run_id")
  analysisRun             AnalysisRun     @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
  featureCoverage         Float           @map("feature_coverage")
  scenarioCoverage        Float           @map("scenario_coverage")
  testCaseCoverage        Float           @map("test_case_coverage")
  automationCoverage      Float           @map("automation_coverage")
  executionReadinessScore Float           @map("execution_readiness_score")
  coverageConfidenceScore Float           @map("coverage_confidence_score")
  coverageClassification  String          @map("coverage_classification")
  coverageGapSummary      Json            @map("coverage_gap_summary")
  details                 Json            @map("details")
  quality                 CoverageQuality?
  createdAt               DateTime        @default(now()) @map("created_at")

  @@map("coverage_reports")
}

model CoverageQuality {
  id                       String         @id @default(uuid())
  reportId                 String         @unique @map("report_id")
  report                   CoverageReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  traceabilityCompleteness Float          @map("traceability_completeness")
  coverageCompleteness     Float          @map("coverage_completeness")
  automationCompleteness   Float          @map("automation_completeness")
  readinessQuality         Float          @map("readiness_quality")
  reportingQuality         Float          @map("reporting_quality")
  createdAt                DateTime       @default(now()) @map("created_at")

  @@map("coverage_quality")
}
